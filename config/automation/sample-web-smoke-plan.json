{
  "version": "1.0.0",
  "createdAt": "2026-03-17T12:00:00+08:00",
  "target": {
    "planName": "监测预警平台自动化冒烟基线",
    "frontendBaseUrl": "http://127.0.0.1:5174",
    "backendBaseUrl": "http://127.0.0.1:9999",
    "loginRoute": "/login",
    "username": "admin",
    "password": "123456",
    "browserPath": "",
    "headless": true,
    "issueDocPath": "docs/22-automation-test-issues-20260316.md",
    "outputPrefix": "config-browser",
    "baselineDir": "config/automation/baselines",
    "scenarioScopes": [
      "delivery",
      "baseline"
    ],
    "failScopes": [
      "delivery"
    ]
  },
  "tags": [
    "playwright",
    "config-driven",
    "web-smoke"
  ],
  "plugins": [
    "builtin-report",
    "builtin-suggestion",
    "capture-response"
  ],
  "scenarios": [
    {
      "key": "login",
      "name": "登录与会话初始化",
      "route": "/login",
      "scope": "delivery",
      "readySelector": "#login-submit",
      "requiresLogin": false,
      "description": "初始化浏览器登录态，作为后续页面校验的前置场景。",
      "businessFlow": "登录鉴权、token 获取与会话建立",
      "featurePoints": [
        "登录页可达",
        "登录接口返回 200",
        "进入受保护工作台"
      ],
      "initialApis": [],
      "steps": [
        {
          "id": "login-fill-username",
          "label": "填写账号",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#login-username"
          },
          "value": "${target.username}",
          "optional": false
        },
        {
          "id": "login-fill-password",
          "label": "填写密码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#login-password"
          },
          "value": "${target.password}",
          "optional": false
        },
        {
          "id": "login-submit",
          "label": "提交登录并等待响应",
          "type": "triggerApi",
          "matcher": "/api/auth/login",
          "action": {
            "type": "click",
            "locator": {
              "type": "css",
              "value": "#login-submit"
            }
          },
          "optional": false
        },
        {
          "id": "login-assert-title",
          "label": "断言首页标题出现",
          "type": "assertText",
          "locator": {
            "type": "css",
            "value": "[data-testid=\"console-page-title\"]"
          },
          "value": "平台首页",
          "optional": false
        }
      ]
    },
    {
      "key": "product-workbench",
      "name": "产品创建与查询",
      "route": "/products",
      "scope": "delivery",
      "readySelector": "#product-key",
      "description": "示例场景：创建产品并基于返回主键查询详情。",
      "businessFlow": "产品模板建模、接口回写与主键查询",
      "featurePoints": [
        "产品创建",
        "返回主键捕获",
        "按 ID 查询产品详情"
      ],
      "initialApis": [],
      "steps": [
        {
          "id": "product-fill-key",
          "label": "填写产品编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#product-key"
          },
          "value": "autotest-product-${runToken}",
          "optional": false
        },
        {
          "id": "product-fill-name",
          "label": "填写产品名称",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#product-name"
          },
          "value": "自动化产品 ${runToken}",
          "optional": false
        },
        {
          "id": "product-fill-protocol",
          "label": "填写协议编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#protocol-code"
          },
          "value": "mqtt-json",
          "optional": false
        },
        {
          "id": "product-fill-format",
          "label": "填写数据格式",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#data-format"
          },
          "value": "JSON",
          "optional": false
        },
        {
          "id": "product-submit",
          "label": "提交产品并捕获主键",
          "type": "triggerApi",
          "matcher": "/api/device/product/add",
          "action": {
            "type": "press",
            "locator": {
              "type": "css",
              "value": "#data-format"
            },
            "value": "Enter"
          },
          "captures": [
            {
              "variable": "productId",
              "path": "payload.data.id"
            }
          ],
          "optional": false
        },
        {
          "id": "product-fill-query-id",
          "label": "填写产品查询主键",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#query-product-id"
          },
          "value": "${variables.productId}",
          "optional": false
        },
        {
          "id": "product-query",
          "label": "按主键查询产品",
          "type": "triggerApi",
          "matcher": "/api/device/product/${variables.productId}",
          "action": {
            "type": "press",
            "locator": {
              "type": "css",
              "value": "#query-product-id"
            },
            "value": "Enter"
          },
          "optional": false
        },
        {
          "id": "product-assert-title",
          "label": "断言当前位于产品页",
          "type": "assertText",
          "locator": {
            "type": "css",
            "value": "[data-testid=\"console-page-title\"]"
          },
          "value": "产品模板中心",
          "optional": false
        }
      ]
    },
    {
      "key": "device-workbench",
      "name": "设备建档与查询",
      "route": "/devices",
      "scope": "baseline",
      "readySelector": "#device-product-key",
      "description": "示例场景：基于产品编码建设设备档案并执行详情查询。",
      "businessFlow": "设备建档、编码检索与详情验证",
      "featurePoints": [
        "设备创建",
        "按 ID 查询",
        "按编码查询"
      ],
      "initialApis": [],
      "steps": [
        {
          "id": "device-fill-product",
          "label": "填写产品编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#device-product-key"
          },
          "value": "autotest-product-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-name",
          "label": "填写设备名称",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#device-name"
          },
          "value": "自动化设备 ${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-code",
          "label": "填写设备编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#device-code"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-secret",
          "label": "填写设备密钥",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#device-secret"
          },
          "value": "123456",
          "optional": false
        },
        {
          "id": "device-fill-client",
          "label": "填写 ClientId",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#client-id"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-username",
          "label": "填写设备用户名",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#username"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-password",
          "label": "填写设备密码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#password"
          },
          "value": "123456",
          "optional": false
        },
        {
          "id": "device-submit",
          "label": "提交设备并捕获主键",
          "type": "triggerApi",
          "matcher": "/api/device/add",
          "action": {
            "type": "click",
            "locator": {
              "type": "role",
              "role": "button",
              "name": "提交设备建档",
              "exact": true
            }
          },
          "captures": [
            {
              "variable": "deviceId",
              "path": "payload.data.id"
            }
          ],
          "optional": false
        },
        {
          "id": "device-fill-query-id",
          "label": "填写设备主键",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#query-device-id"
          },
          "value": "${variables.deviceId}",
          "optional": false
        },
        {
          "id": "device-query-by-id",
          "label": "按 ID 查询设备",
          "type": "triggerApi",
          "matcher": "/api/device/${variables.deviceId}",
          "action": {
            "type": "click",
            "locator": {
              "type": "role",
              "role": "button",
              "name": "按 ID 查询",
              "exact": true
            }
          },
          "optional": false
        },
        {
          "id": "device-fill-query-code",
          "label": "填写设备编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#query-device-code"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-query-by-code",
          "label": "按编码查询设备",
          "type": "triggerApi",
          "matcher": "/api/device/code/autotest-device-${runToken}",
          "action": {
            "type": "click",
            "locator": {
              "type": "role",
              "role": "button",
              "name": "按编码查询",
              "exact": true
            }
          },
          "optional": false
        },
        {
          "id": "device-assert-title",
          "label": "断言当前位于设备页",
          "type": "assertText",
          "locator": {
            "type": "css",
            "value": "[data-testid=\"console-page-title\"]"
          },
          "value": "设备运维中心",
          "optional": false
        },
        {
          "id": "device-assert-visual-page",
          "label": "?????????",
          "type": "assertScreenshot",
          "screenshotTarget": "page",
          "baselineName": "device-workbench-page",
          "threshold": 0.002,
          "fullPage": true,
          "optional": false
        }
      ]
    }
  ]
}
