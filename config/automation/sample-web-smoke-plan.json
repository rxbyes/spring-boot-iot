{
  "version": "1.0.0",
  "createdAt": "2026-03-17T12:00:00+08:00",
  "target": {
    "planName": "监测预警平台自动化冒烟基线",
    "frontendBaseUrl": "http://127.0.0.1:5174",
    "backendBaseUrl": "http://127.0.0.1:9999",
    "loginRoute": "/login",
    "username": "admin",
    "password": "123456",
    "browserPath": "",
    "headless": true,
    "issueDocPath": "docs/archive/22-automation-test-issues-20260316.md",
    "outputPrefix": "config-browser",
    "baselineDir": "config/automation/baselines",
    "scenarioScopes": [
      "delivery",
      "baseline"
    ],
    "failScopes": [
      "delivery"
    ]
  },
  "tags": [
    "playwright",
    "config-driven",
    "web-smoke"
  ],
  "plugins": [
    "builtin-report",
    "builtin-suggestion",
    "capture-response"
  ],
  "scenarios": [
    {
      "key": "login",
      "name": "登录与会话初始化",
      "route": "/login",
      "scope": "delivery",
      "readySelector": "#login-submit",
      "requiresLogin": false,
      "description": "初始化浏览器登录态，作为后续页面校验的前置场景。",
      "businessFlow": "登录鉴权、token 获取与会话建立",
      "featurePoints": [
        "登录页可达",
        "登录接口返回 200",
        "进入受保护工作台"
      ],
      "initialApis": [],
      "steps": [
        {
          "id": "login-fill-username",
          "label": "填写账号",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#login-username"
          },
          "value": "${target.username}",
          "optional": false
        },
        {
          "id": "login-fill-password",
          "label": "填写密码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#login-password"
          },
          "value": "${target.password}",
          "optional": false
        },
        {
          "id": "login-submit",
          "label": "提交登录并等待响应",
          "type": "triggerApi",
          "matcher": "/api/auth/login",
          "action": {
            "type": "click",
            "locator": {
              "type": "css",
              "value": "#login-submit"
            }
          },
          "optional": false
        },
        {
          "id": "login-assert-title",
          "label": "断言进入治理入口",
          "type": "assertText",
          "locator": {
            "type": "css",
            "value": "body"
          },
          "value": "平台治理",
          "optional": false
        }
      ]
    },
    {
      "key": "product-workbench",
      "name": "产品创建与查询",
      "route": "/products",
      "scope": "delivery",
      "readySelector": "#quick-search",
      "description": "示例场景：创建产品并基于返回主键查询详情。",
      "businessFlow": "产品模板建模、接口回写与主键查询",
      "featurePoints": [
        "产品创建",
        "返回主键捕获",
        "按当前快速搜索筛选产品台账"
      ],
      "initialApis": [],
      "steps": [
        {
          "id": "product-open-create-drawer",
          "label": "打开新增产品抽屉",
          "type": "click",
          "locator": {
            "type": "role",
            "role": "button",
            "name": "新增产品",
            "exact": true
          },
          "optional": false
        },
        {
          "id": "product-fill-key",
          "label": "填写产品编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#product-key"
          },
          "value": "autotest-product-${runToken}",
          "optional": false
        },
        {
          "id": "product-fill-name",
          "label": "填写产品名称",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#product-name"
          },
          "value": "自动化产品 ${runToken}",
          "optional": false
        },
        {
          "id": "product-fill-protocol",
          "label": "填写协议编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#protocol-code"
          },
          "value": "mqtt-json",
          "optional": false
        },
        {
          "id": "product-fill-format",
          "label": "填写数据格式",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#data-format"
          },
          "value": "JSON",
          "optional": false
        },
        {
          "id": "product-submit",
          "label": "提交产品并捕获主键",
          "type": "triggerApi",
          "matcher": "/api/device/product/add",
          "action": {
            "type": "click",
            "locator": {
              "type": "css",
              "value": "#product-submit-button"
            }
          },
          "captures": [
            {
              "variable": "productId",
              "path": "payload.data.id"
            }
          ],
          "optional": false
        },
        {
          "id": "product-fill-quick-search",
          "label": "填写产品快速搜索",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#quick-search"
          },
          "value": "自动化产品 ${runToken}",
          "optional": false
        },
        {
          "id": "product-query",
          "label": "按产品名称查询台账",
          "type": "triggerApi",
          "matcher": "/api/device/product/page",
          "action": {
            "type": "click",
            "locator": {
              "type": "role",
              "role": "button",
              "name": "查询",
              "exact": true
            }
          },
          "optional": false
        },
        {
          "id": "product-assert-key",
          "label": "断言列表出现产品编码",
          "type": "assertText",
          "locator": {
            "type": "css",
            "value": "body"
          },
          "value": "autotest-product-${runToken}",
          "optional": false
        }
      ]
    },
    {
      "key": "device-workbench",
      "name": "设备资产建档与库存校验",
      "route": "/devices",
      "scope": "baseline",
      "readySelector": "#quick-search",
      "description": "示例场景：在设备资产列表打开抽屉建档，并通过列表筛选验证设备已成功入库。",
      "businessFlow": "设备建档、列表筛选与库存校验",
      "featurePoints": [
        "设备创建",
        "列表筛选",
        "库存校验"
      ],
      "initialApis": [],
      "steps": [
        {
          "id": "device-open-create-drawer",
          "label": "打开新增设备抽屉",
          "type": "click",
          "locator": {
            "type": "role",
            "role": "button",
            "name": "新增设备",
            "exact": true
          },
          "optional": false
        },
        {
          "id": "device-select-product",
          "label": "选择产品",
          "type": "selectOption",
          "locator": {
            "type": "css",
            "value": "#device-form-product-key"
          },
          "optionText": "autotest-product-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-name",
          "label": "填写设备名称",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#device-name"
          },
          "value": "自动化设备 ${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-code",
          "label": "填写设备编码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#device-code"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-secret",
          "label": "填写设备密钥",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#device-secret"
          },
          "value": "123456",
          "optional": false
        },
        {
          "id": "device-fill-client",
          "label": "填写 ClientId",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#client-id"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-username",
          "label": "填写设备用户名",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#username"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-fill-password",
          "label": "填写设备密码",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#password"
          },
          "value": "123456",
          "optional": false
        },
        {
          "id": "device-submit",
          "label": "提交设备并捕获主键",
          "type": "triggerApi",
          "matcher": "/api/device/add",
          "action": {
            "type": "click",
            "locator": {
              "type": "role",
              "role": "button",
              "name": "提交设备建档",
              "exact": true
            }
          },
          "captures": [
            {
              "variable": "deviceId",
              "path": "payload.data.id"
            }
          ],
          "optional": false
        },
        {
          "id": "device-fill-quick-search",
          "label": "填写设备快速搜索",
          "type": "fill",
          "locator": {
            "type": "css",
            "value": "#quick-search"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-query",
          "label": "按设备编码查询台账",
          "type": "triggerApi",
          "matcher": "/api/device/page",
          "action": {
            "type": "click",
            "locator": {
              "type": "role",
              "role": "button",
              "name": "查询",
              "exact": true
            }
          },
          "optional": false
        },
        {
          "id": "device-assert-code",
          "label": "断言列表出现设备编码",
          "type": "assertText",
          "locator": {
            "type": "css",
            "value": "body"
          },
          "value": "autotest-device-${runToken}",
          "optional": false
        },
        {
          "id": "device-assert-visual-page",
          "label": "断言设备资产页视觉基线",
          "type": "assertScreenshot",
          "screenshotTarget": "page",
          "baselineName": "device-workbench-page",
          "threshold": 0.002,
          "fullPage": true,
          "optional": true
        }
      ]
    }
  ]
}
